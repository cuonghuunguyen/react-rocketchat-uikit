{
  "name": "react-rocketchat-uikit",
  "version": "1.1.0",
  "description": "React reconciler for building Rocket.Chat Apps UI Kit blocks",
  "license": "MIT",
  "author": "Cuong Huu Nguyen <CuongHuuNguyen98@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/cuonghuunguyen/react-rocketchat-uikit.git"
  },
  "keywords": [
    "rocketchat",
    "uikit",
    "react",
    "reconciler",
    "blocks",
    "jsx"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "jest-util": "^30.4.1",
    "react": "^19.0.0",
    "react-reconciler": "^0.33.0"
  },
  "devDependencies": {
    "@rocket.chat/apps-engine": "^1.62.0",
    "@rocket.chat/ui-kit": "^1.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.0",
    "@types/react-reconciler": "^0.33.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
